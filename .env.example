# ========================================
# ARBPRO ENVIRONMENT CONFIGURATION
# AI Arbitrage Bot v7.0
# ========================================
# 
# INSTRUCTIONS:
# 1. Fill in YOUR values (replace placeholders)
# 2. Save this as .env in the root directory
# 3. Run: python verify_system.py
# 4. If all green ✅, you're ready to go!
#
# ⚠️  KEEP THIS FILE PRIVATE - NEVER COMMIT TO GIT
# Add .env to .gitignore
# ========================================

# ========================================
# ENVIRONMENT SELECTION
# ========================================
# Options: testnet, production
# Choose ONE:
ENVIRONMENT=testnet


# ========================================
# BINANCE TESTNET CREDENTIALS
# ========================================
# Get from: https://testnet.binance.vision
# Click: API Management
# 
BINANCE_TESTNET_API_KEY=your_binance_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_binance_testnet_secret_here


# ========================================
# BINANCE PRODUCTION CREDENTIALS
# ========================================
# ⚠️  ONLY FILL IF USING PRODUCTION
# Get from: https://www.binance.com/en/account/api-management
# 
# KEEP YOUR PRODUCTION KEYS SECURE!
# DO NOT share or commit these to version control
#
BINANCE_PRODUCTION_API_KEY=your_binance_production_api_key_here
BINANCE_PRODUCTION_SECRET=your_binance_production_secret_here


# ========================================
# BYBIT TESTNET CREDENTIALS
# ========================================
# Get from: https://testnet.bybit.com
# Click: Account → API
# 
BYBIT_TESTNET_API_KEY=your_bybit_testnet_api_key_here
BYBIT_TESTNET_SECRET=your_bybit_testnet_secret_here


# ========================================
# BYBIT PRODUCTION CREDENTIALS
# ========================================
# ⚠️  ONLY FILL IF USING PRODUCTION
# Get from: https://www.bybit.com/en-US/
# Click: Account → API
#
BYBIT_PRODUCTION_API_KEY=your_bybit_production_api_key_here
BYBIT_PRODUCTION_SECRET=your_bybit_production_secret_here


# ========================================
# PROXY CONFIGURATION (Optional)
# ========================================
# Only set if you experience:
# - ISP blocking Bybit
# - Connection timeouts
# - Network errors
#
# Format: http://proxy_ip:port
# Example: http://47.56.69.11:3128
#
# Leave empty to disable:
HTTP_PROXY=
HTTPS_PROXY=
ENABLE_PROXY_FALLBACK=true


# ========================================
# API SETTINGS
# ========================================
# Request timeout in seconds (default: 10)
# Increase if you have slow internet
API_REQUEST_TIMEOUT=10

# Enable rate limiting (recommended for production)
API_RATE_LIMIT_ENABLED=true

# Number of retry attempts on failure
API_RETRY_ATTEMPTS=3

# Delay between retries in seconds
API_RETRY_DELAY=1.0


# ========================================
# AI & LLM CONFIGURATION
# ========================================
# Gemini API Key (for market analysis)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (for fast LLM inference)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here


# ========================================
# SECURITY CONFIGURATION
# ========================================
# JWT Secret for authentication
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_random_32_character_secret_key_here


# ========================================
# OPTIONAL: ADDITIONAL EXCHANGES
# ========================================
# For future expansion to Kraken, Coinbase, etc.

# Kraken Testnet
KRAKEN_TESTNET_API_KEY=
KRAKEN_TESTNET_SECRET=

# Kraken Production
KRAKEN_PRODUCTION_API_KEY=
KRAKEN_PRODUCTION_SECRET=

# Coinbase Testnet
COINBASE_TESTNET_API_KEY=
COINBASE_TESTNET_SECRET=

# Coinbase Production
COINBASE_PRODUCTION_API_KEY=
COINBASE_PRODUCTION_SECRET=


# ========================================
# ADVANCED OPTIONS (Expert Users Only)
# ========================================
# Max trades per hour (0 = unlimited)
MAX_TRADES_PER_HOUR=0

# Min spread threshold (%)
MIN_SPREAD_PERCENT=0.3

# Max position size in USDT
MAX_POSITION_SIZE=1000

# Max daily loss limit (%)
MAX_DAILY_LOSS_PERCENT=2

# Enable notifications
ENABLE_NOTIFICATIONS=true

# Notification email (optional)
NOTIFICATION_EMAIL=your_email@example.com
